# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.html text eol=lf
*.css text eol=lf

# Prevent lockfile merge conflicts
pnpm-lock.yaml merge=ours linguist-generated

# Mark generated files
dist/** linguist-generated
coverage/** linguist-generated
