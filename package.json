{
  "name": "did-stellar",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the did:stellar SDK (@acta-team/did-stellar) and the standalone did-stellar-api HTTP service.",
  "license": "MIT",
  "author": "ACTA",
  "homepage": "https://github.com/ACTA-Team/did-stellar",
  "repository": {
    "type": "git",
    "url": "https://github.com/ACTA-Team/did-stellar.git"
  },
  "engines": {
    "node": ">=22.22.0 <25",
    "pnpm": ">=9 <11"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "pnpm -r test:coverage",
    "clean": "turbo run clean && rimraf .turbo node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "axios@<1.15.2": "^1.15.2"
    },
    "auditConfig": {
      "ignoreCves": []
    }
  }
}
