# did-stellar-api — environment configuration.
#
# Every variable is optional in development; production deployments
# SHOULD pin NETWORK_TYPE, STELLAR_RPC_URL and DID_REGISTRY_CONTRACT_ID.

# Listen port.
PORT=8080

# Network the resolver operates on. Closed set: mainnet | testnet.
NETWORK_TYPE=testnet

# Override the canonical did-stellar-registry contract ID.
# Required in mainnet until the Bloque E deployment lands.
# Testnet default: CB7ATU7SF5QUKJMSULJDJVWJZVDXC23HTZX6NFUDTSFPVT6MA575NNZJ
# DID_REGISTRY_CONTRACT_ID=

# Override the Stellar RPC URL. Defaults to the SDF public endpoint per network.
# Can point to a private pool / balancer.
# STELLAR_RPC_URL=

# Optional Redis URL. When set:
#   - DID resolutions are cached for RESOLVER_CACHE_TTL_SECONDS.
#   - Rate limiting uses a sliding-window counter in Redis (shared
#     across replicas).
# When unset both caches degrade to per-process in-memory.
# REDIS_URL=redis://127.0.0.1:6379

# TTL for the resolver cache, in seconds. Default 30.
RESOLVER_CACHE_TTL_SECONDS=30

# Per-IP rate limit. Defaults to 120 requests / minute.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60

# CORS allow-list. Comma-separated origins. `*` is permitted (default for
# a resolver — verifier scripts come from anywhere).
CORS_ORIGINS=*

# Log level (pino): trace | debug | info | warn | error | fatal.
LOG_LEVEL=info

# --- Analytics (PostHog) — OPTIONAL, opt-in --------------------------------
# When POSTHOG_API_KEY is unset the service emits no events and allocates no
# analytics client. Set it to the project's write-only token (phc_...) to
# capture did_resolved / did_mutation / did_mutation_failed events. DIDs are
# never sent raw — the distinctId is a SHA-256 hash and properties carry only
# counts and enums.
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com
