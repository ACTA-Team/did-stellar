      "id": "vector-4",
      "description": "Concurrent update conflict: two callers both read version=1 and both attempt update(expected_version=1). First succeeds; second fails with VersionMismatch.",
      "input": {
        "did": "did:stellar:testnet:aaaqeayeaudaocajbifqydiob4",
        "initial_version": 1,
        "caller_a_update": { "expected_version": 1, "new_version_after": 2 },
        "caller_b_update": { "expected_version": 1, "error": "VersionMismatch" }
      },
      "expected": {
        "caller_a": "success — version becomes 2",
        "caller_b": "error VersionMismatch — on-chain version is now 2, not 1"
      }
